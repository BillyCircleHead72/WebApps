    <!DOCTYPE html>
    <html>
        <head>
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>Task Tracker WebApp</title>

            <style>
                .title {
                    margin-left: 100px;
                }
                .time {
                    position: absolute;
                    margin-top: -10px;
                    margin-left: 70px;
                    font-size: 40px;
                }
                .texts { 
                    margin-top: -0px;
                    margin-left: 190px;
                    font-size: 40px;
                    position: fixed;
                    line-height: 0.75;
                    text-align: center;

                }
                html, body {
                    margin: 0;
                    padding: 0;
                    height: 100%;
                }
                body {
                    font-family: cursive;
                    margin: 0;
                    background-image: url("task tracker background.png");
                    background-color: #e0a048;
                    background-size: cover;
                    background-position: center; 
                    background-repeat: no-repeat;
                    overflow-x: hidden;
                }
                .content {
                    position: relative;
                    top: -5%;
                    transform: none;
                    text-align: center;
                    margin-top: 100px;
                }
                button {
                    margin-top: 5px;
                    font-size: 16px;
                    font-family: cursive;
                    text-align: center;
                    background-color: #e8d3b5;
                    border: 2.5px solid #705532;
                    outline: #705532;
                }
                input {
                    margin-top: 5px;
                    font-size: 16px;
                    font-family: cursive;
                    text-align: center;
                    background-color: #e8d3b5;
                    border: 2.5px solid #705532;
                    outline: #705532;
                }
                input[type="checkbox"] {
                    accent-color: #e0a048;
                    width: 20px;
                    height: 20px;
                }
                ol {
                    margin-top: -20px;
                }
                li {
                    margin-left: 0px;
                    display: flex;
                    align-items: center;
        
                }
                li span {
                    flex: 1;
                    text-align: center;
                    max-width: 250px;
                }
                .credits {
                    text-align: center;
                    position: absolute;
                    left: 35%;
                    top: 80%;
                }
            </style>
        </head>

        <body>
            
            <h1 class="title">~Task Tracker~</h1>
            <h2 id="time" class="time">0:00</h2>
            <h2 id="timesUp" class="texts" style="display: none;">Time is Up!!<br>
                <span style="font-size: 10px;">Please Reset the Timer..</span></h2>
            
            <h2 id="minus" class="texts" style="display: none;">Invalid Input<br>
                <span style="font-size: 10px;">Please enter a valid number..</span></h2>
                
            <div class="content">
            <input type="number" id="minutesInput" placeholder="Input Minutes Here :D">
            <button onclick="startTimer()">Start</button>
            <button onclick="pauseTimer()">Pause</button>
            <button onclick="resetTimer()">Reset</button>
            <br>
            <input type="text" id="taskInput" placeholder="Enter Task...">
            <button  onclick="addTask()">Add Task</button>
            </div>

            <ol id="taskList"></ol>

            <p class="credits"><span style="font-weight: 500;">by: Orang yang <span style="font-weight: 1000;">masih</span><br> menginginkanmu</span></p>



        </body>

        <script>
            const max_tasks = 10
            let tasks = [];
            //save tasks
            function saveTasks() {
                sessionStorage.setItem("tasks", JSON.stringify(tasks));
            }

            //load tasks
            function loadTasks() {
                let savedTasks = sessionStorage.getItem("tasks");
                if (savedTasks) {
                    tasks = JSON.parse(savedTasks);
                    displayTasks();
                }
            }

//Tasks code

            //Add tasks
            function addTask() {
                let agenda = document.getElementById("taskInput").value;

                if (tasks.length > max_tasks-1) {
                    return;
                }
                if (agenda === "") {
                    return;
                }

                tasks.push({
                    name: agenda,
                    done: false
                });

                document.getElementById("taskInput").value = "";

                saveTasks();
                displayTasks();
            }

            function displayTasks() {
                let list = document.getElementById("taskList");

                list.innerHTML = "";
                for (let i = 0; i < tasks.length; i++) {
                    //list
                    let li = document.createElement("li");

                    //checkbox
                    let checkbox = document.createElement("input");
                    checkbox.type = "checkbox";
                    checkbox.checked = tasks[i].done;
                    checkbox.onclick = function () {
                        tasks[i].done = !tasks[i].done;
                        saveTasks();
                        displayTasks();
                    };

                    //name of task
                    let span = document.createElement("span");
                    span.textContent = tasks[i].name;

                    //delete button
                    let deleteButton = document.createElement("button");
                    deleteButton.textContent = "Delete";
                    deleteButton.onclick = function () {
                        tasks.splice(i,1); //remove task from array
                        saveTasks();
                        displayTasks();
                    };
                    if (tasks[i].done) {
                        span.style.textDecoration= "line-through";
                    }

                    li.appendChild(checkbox);
                    li.appendChild(span);
                    li.appendChild(deleteButton);
                    list.appendChild(li);
                }
            }
            


//Timer code
            let endTime = null;
            let timer = null;
            let minutes;

            function timerDisplay(t) {
                let minutes = Math.floor(t / 60);
                let seconds = t % 60;

                if (seconds < 10) {
                    seconds = "0" + seconds;
                }
                document.getElementById("time").textContent =
                minutes + ":" + seconds;
            }

            function startTimer() {
                
                if (timer !== null) {
                    return;
                }
                let savedRemaining = sessionStorage.getItem("remainingTime");

                if (savedRemaining) {
                    let remaining = parseInt(savedRemaining);

                    if (!isNaN(remaining)) {
                        endTime = Date.now() + remaining;
                    }

                    sessionStorage.removeItem("remainingTime");
                }
                if (!endTime) {
                    minutes = parseInt(document.getElementById("minutesInput").value);
                    if (minutes <= 0 || isNaN(minutes)) {
                        document.getElementById("minus").style.display= "block";
                        return;
                    } else {
                        document.getElementById("minus").style.display= "none";
                    }
                    endTime = Date.now() + (minutes * 60 * 1000);
                }
                let now = Date.now();
                let remaining = Math.max(0, Math.ceil((endTime - now) / 1000) - 1);
                timerDisplay(remaining);

                timer = setInterval(function () {

                    let now = Date.now();
                    let remaining = Math.max(0, Math.ceil((endTime - now) / 1000) - 1);

                    if (remaining <= 0) {
                    clearInterval(timer);
                    timer = null;
                    endTime = null;

                    document.getElementById("timesUp").style.display = "block";
                    navigator.vibrate(250);

                    timerDisplay(0);
                    return;
                    }

                    timerDisplay(remaining);

                    }, 1000);
                    
            }

            function pauseTimer() {
                clearInterval(timer);
                timer = null;
                
                if (endTime) {
                    let now = Date.now();
                    let remaining = endTime - now;

                    if (!isNaN(remaining)) {
                        sessionStorage.setItem("remainingTime", remaining);
                    }
                }
            }

            function resetTimer() {
                clearInterval(timer);
                timer = null;
                endTime = null;
                document.getElementById("timesUp").style.display= "none"
                document.getElementById("minus").style.display= "none";
                sessionStorage.removeItem("remainingTime");
                timerDisplay(0);
            }

            loadTasks();
            timerDisplay(0);
        </script>

    </html>
